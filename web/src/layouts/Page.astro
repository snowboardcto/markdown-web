---
// Story 2.1 — minimal, well-formed HTML5 document shell (AC3).
// Story 2.2 — adds the GitHub-style reading theme (design tokens, typography,
// 760px measure, light code highlighting) as a static, hashed CSS asset.
//
// Wraps rendered markdown in a valid <html lang> -> <head> -> <body> document
// with the content inside a semantic <main>/<article>. The reading theme ships
// as pure static CSS (no `client:*` island, no runtime JS for styling), so the
// page stays server-rendered and survives JS-disabled (AC2).
//
// Story 2.6 — adds the site-header + pitch-card chrome here, in the SINGLE
// shared layout, so all three surfaces (content [...slug], the index, and the
// 404) inherit it with one edit. <SiteHeader/> renders BEFORE <main> (the
// implicit `banner` landmark); <PitchCard/> renders AFTER </main> (the implicit
// `contentinfo` landmark) — both direct children of <body>, so the content
// <h1> inside <article> stays the page's SOLE <h1>. Both are static HTML + CSS
// (no `client:*`, no <script>): JS-free and crawlable.
import '../styles/github.css';
import SiteHeader from '../components/SiteHeader.astro';
import PitchCard from '../components/PitchCard.astro';

interface Props {
  /** Deterministic, never-empty page title (H1 / front-matter title / slug). */
  title: string;
}

const { title } = Astro.props;

// Story 5.1 — Living Link (AC3): build the canonical absolute URL for this page
// from Astro.site (the production origin set in astro.config.mjs) + the route path.
// The URL is pure static — no query string, no fragment artifacts from the preview
// host. Derives from the SAME route path Astro already emits (no re-implementation
// of slug logic). For the index "/" the canonical is "https://themarkdownweb.com/".
// Trailing slash is stripped from non-root paths (e.g. "/x/" → "/x") so the canonical
// is the clean slug form, consistent with PageEndpointResolver on the native side.
const rawPathname = Astro.url.pathname;
const canonicalPathname = rawPathname.length > 1 && rawPathname.endsWith('/')
  ? rawPathname.slice(0, -1)
  : rawPathname;
const canonical = new URL(canonicalPathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="canonical" href={canonical.href} />
  </head>
  <body>
    <SiteHeader />
    <main>
      <article>
        <slot />
      </article>
    </main>
    <PitchCard />
  </body>
</html>
