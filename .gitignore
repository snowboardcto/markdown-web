# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
web/dist/

# Story 2.7 — API content-negotiation bundle (Decision A): a verbatim build-time
# copy of content/**/*.md + a generated slug->file manifest. Both regenerate
# deterministically from content/ via `cd api && npm run build`; never commit
# the copy (content/ stays the single source of truth).
api/negotiate/content/
api/negotiate/manifest.json
api/local.settings.json

# Astro
.astro/

# Playwright (test runner artifacts — never commit)
web/test-results/
web/playwright-report/
web/.playwright/

# Bicep compiled ARM output (transpiled artifact — never commit; recompile from .bicep).
# Narrow to the known template name so a future infra/staticwebapp.config.json stays tracked.
infra/main.json

# Logs / env
*.log
.env
.env.local
.DS_Store
