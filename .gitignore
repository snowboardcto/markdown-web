# Dependencies
node_modules/
**/node_modules/

# Build output
dist/
web/dist/

# Story 2.7 — API content-negotiation bundle (Decision A): a verbatim build-time
# copy of content/**/*.md + a generated slug->file manifest + a bundled copy of
# the shared slug logic. All regenerate deterministically from content/ +
# web/src/lib/slug.mjs via `cd api && npm run build`; never commit them (content/
# and web/src/lib/slug.mjs stay the single sources of truth).
api/negotiate/content/
api/negotiate/manifest.json
api/negotiate/slug.mjs
api/local.settings.json

# Astro
.astro/

# Playwright (test runner artifacts — never commit)
web/test-results/
web/playwright-report/
web/.playwright/

# Bicep compiled ARM output (transpiled artifact — never commit; recompile from .bicep).
# Narrow to the known template name so a future infra/staticwebapp.config.json stays tracked.
infra/main.json

# Logs / env
*.log
.env
.env.local
.DS_Store
