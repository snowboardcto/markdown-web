<Window x:Class="TheMarkdownWeb.App.ApiKeyEntryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add your API key"
        Width="420"
        Height="240"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Labeled key input. The adjacent label + AutomationProperties.Name name the field. -->
        <TextBlock Grid.Row="0"
                   Text="API key"
                   Margin="0,0,0,4" />

        <PasswordBox x:Name="ApiKeyInput"
                     Grid.Row="1"
                     Focusable="True"
                     AutomationProperties.Name="API key"
                     Margin="0,0,0,12" />

        <!-- BYO-key disclosure (text set in code-behind from the VM's DisclosureText). -->
        <TextBlock x:Name="DisclosureText"
                   Grid.Row="2"
                   TextWrapping="Wrap"
                   Foreground="#444444"
                   Margin="0,0,0,12" />

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="SaveButton"
                    Content="Save"
                    AutomationProperties.Name="Save"
                    MinWidth="72"
                    Margin="0,0,8,0"
                    IsDefault="True"
                    Click="SaveButton_Click" />
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    AutomationProperties.Name="Cancel"
                    MinWidth="72"
                    IsCancel="True"
                    Click="CancelButton_Click" />
        </StackPanel>
    </Grid>
</Window>
