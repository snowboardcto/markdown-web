<Window x:Class="TheMarkdownWeb.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Markdown Web"
        Height="600"
        Width="800">
    <DockPanel LastChildFill="True">
        <!-- Browser-like toolbar, docked at the top of the window (client-toolbar). -->
        <Border DockPanel.Dock="Top"
                Background="#F3F3F3"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- Navigation buttons: Back / Forward / Reload, left-aligned. -->
                    <ColumnDefinition Width="Auto" />
                    <!-- Reserved space for the Story 3.2 address bar (and the Epic 4
                         personality selector). Intentionally EMPTY at this story — do not build. -->
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button x:Name="BackButton"
                            TabIndex="0"
                            Content="&#x2039;"
                            AutomationProperties.Name="Back"
                            ToolTip="Back"
                            MinWidth="32"
                            Margin="0,0,2,0"
                            Padding="6,2"
                            Click="BackButton_Click" />
                    <Button x:Name="ForwardButton"
                            TabIndex="1"
                            Content="&#x203A;"
                            AutomationProperties.Name="Forward"
                            ToolTip="Forward"
                            MinWidth="32"
                            Margin="0,0,2,0"
                            Padding="6,2"
                            Click="ForwardButton_Click" />
                    <Button x:Name="ReloadButton"
                            TabIndex="2"
                            Content="&#x27F3;"
                            AutomationProperties.Name="Reload"
                            ToolTip="Reload"
                            MinWidth="32"
                            Padding="6,2"
                            Click="ReloadButton_Click" />
                </StackPanel>

                <!-- Grid.Column 1 (Width="*") — the address bar: lock + host/path input + ".md only" tag. -->
                <Border x:Name="AddressBar"
                        Grid.Column="1"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="6,0,0,0"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- (a) Lock indicator. The glyph alone is NOT the accessible name. -->
                        <TextBlock x:Name="LockIndicator"
                                   Grid.Column="0"
                                   Text="&#x1F512;"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   AutomationProperties.Name="Secure" />

                        <!-- (b) Host/path input — keyboard-reachable, after Reload in tab order. -->
                        <TextBox x:Name="AddressInput"
                                 Grid.Column="1"
                                 TabIndex="3"
                                 Focusable="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding AddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Address"
                                 KeyDown="AddressInput_KeyDown" />

                        <!-- (c) ".md only" tag — text is EXACTLY ".md only" (ordinal). -->
                        <TextBlock x:Name="MdOnlyTag"
                                   Grid.Column="2"
                                   Text=".md only"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Foreground="#666666"
                                   AutomationProperties.Name="Loads .md pages only" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Named, empty content host. Story 3.3 / 3.6 will fill this with the Markdig -> FlowDocument
             render. It renders nothing at this story. -->
        <Border x:Name="ContentHost" />
    </DockPanel>
</Window>
