<Window x:Class="TheMarkdownWeb.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Markdown Web"
        Height="600"
        Width="800">
    <DockPanel LastChildFill="True">
        <!-- Browser-like toolbar, docked at the top of the window (client-toolbar). -->
        <Border DockPanel.Dock="Top"
                Background="#F3F3F3"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1"
                Padding="6,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <!-- col 0: Navigation buttons: Back / Forward / Reload, left-aligned. -->
                    <ColumnDefinition Width="Auto" />
                    <!-- col 1: the Story 3.2 address bar (keeps Width="*" fill). -->
                    <ColumnDefinition Width="*" />
                    <!-- col 2: the Story 4.2 personality selector (Q-Placement: a NEW Auto column to
                         the RIGHT of the address bar, so the address bar keeps filling and the nav
                         StackPanel is undisturbed). -->
                    <ColumnDefinition Width="Auto" />
                    <!-- col 3: the Story 4.4 target-language picker (Q-Lang-UX: shown only when the
                         Translate persona is selected; collapsed otherwise so it does not clutter the
                         toolbar for the other personas). -->
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button x:Name="BackButton"
                            TabIndex="0"
                            Content="&#x2039;"
                            AutomationProperties.Name="Back"
                            ToolTip="Back"
                            MinWidth="32"
                            Margin="0,0,2,0"
                            Padding="6,2"
                            Click="BackButton_Click" />
                    <Button x:Name="ForwardButton"
                            TabIndex="1"
                            Content="&#x203A;"
                            AutomationProperties.Name="Forward"
                            ToolTip="Forward"
                            MinWidth="32"
                            Margin="0,0,2,0"
                            Padding="6,2"
                            Click="ForwardButton_Click" />
                    <Button x:Name="ReloadButton"
                            TabIndex="2"
                            Content="&#x27F3;"
                            AutomationProperties.Name="Reload"
                            ToolTip="Reload"
                            MinWidth="32"
                            Padding="6,2"
                            Click="ReloadButton_Click" />
                </StackPanel>

                <!-- Grid.Column 1 (Width="*") — the address bar: lock + host/path input + ".md only" tag. -->
                <Border x:Name="AddressBar"
                        Grid.Column="1"
                        Background="White"
                        BorderBrush="#D0D0D0"
                        BorderThickness="1"
                        CornerRadius="4"
                        Margin="6,0,0,0"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- (a) Lock indicator. The glyph alone is NOT the accessible name. -->
                        <TextBlock x:Name="LockIndicator"
                                   Grid.Column="0"
                                   Text="&#x1F512;"
                                   VerticalAlignment="Center"
                                   Margin="0,0,6,0"
                                   AutomationProperties.Name="Secure" />

                        <!-- (b) Host/path input — keyboard-reachable, after Reload in tab order. -->
                        <TextBox x:Name="AddressInput"
                                 Grid.Column="1"
                                 TabIndex="3"
                                 Focusable="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 VerticalAlignment="Center"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding AddressText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Address"
                                 KeyDown="AddressInput_KeyDown" />

                        <!-- (c) ".md only" tag — text is EXACTLY ".md only" (ordinal). -->
                        <TextBlock x:Name="MdOnlyTag"
                                   Grid.Column="2"
                                   Text=".md only"
                                   VerticalAlignment="Center"
                                   Margin="6,0,0,0"
                                   Foreground="#666666"
                                   AutomationProperties.Name="Loads .md pages only" />
                    </Grid>
                </Border>

                <!-- Grid.Column 2 (Width="Auto") — the Story 4.2 personality selector. Labeled +
                     keyboard-reachable (UX-DR9): AutomationProperties.Name="Personality", Focusable,
                     tab stop. Tab order: PersonalitySelector(4) after AddressInput(3), before
                     ContentScroll(5). Items + selection are set in code-behind from the selection VM
                     (ItemsSource = Options, SelectedItem two-way = Current); DisplayMemberPath shows
                     each persona's DisplayName. -->
                <ComboBox x:Name="PersonalitySelector"
                          Grid.Column="2"
                          TabIndex="4"
                          Focusable="True"
                          Margin="6,0,0,0"
                          MinWidth="120"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Personality"
                          DisplayMemberPath="DisplayName"
                          SelectionChanged="PersonalitySelector_SelectionChanged" />

                <!-- Grid.Column 3 (Width="Auto") — the Story 4.4 target-language picker. Labeled +
                     keyboard-reachable (UX-DR9): AutomationProperties.Name="Target language", Focusable,
                     a tab stop. A NON-editable ComboBox of common languages (an editable ComboBox makes the
                     OUTER control a non-tab-stop — focus goes to its inner textbox — which would fail the
                     keyboard-reachability assertion; the non-editable picker is a clean tab stop like the
                     PersonalitySelector). Tab order: LanguagePicker(5) after PersonalitySelector(4), before
                     ContentScroll(6). Shown only when the Translate persona is selected (code-behind toggles
                     Visibility). -->
                <ComboBox x:Name="LanguagePicker"
                          Grid.Column="3"
                          TabIndex="5"
                          Focusable="True"
                          Visibility="Collapsed"
                          Margin="6,0,0,0"
                          MinWidth="120"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="Target language"
                          ToolTip="Target language"
                          SelectionChanged="LanguagePicker_SelectionChanged" />
            </Grid>
        </Border>

        <!-- Content host (Story 3.5): a read-only FlowDocumentScrollViewer hosts the rendered
             FlowDocument. FlowDocumentScrollViewer has no editing surface (read-only by
             construction) and routes Hyperlink.RequestNavigate for hosted hyperlinks. -->
        <Border x:Name="ContentHost">
            <!-- Story 3.6 (AC4): ContentScroll is keyboard-reachable so a keyboard user can reach +
                 scroll the rendered content (FlowDocumentScrollViewer is NOT a tab stop by default).
                 Story 4.4 (Q-Lang-UX): TabIndex bumped 5 -> 6 so the Translate language picker sits at 5 —
                 the walk is Back(0)/Forward(1)/Reload(2)/AddressInput(3)/PersonalitySelector(4)/
                 LanguagePicker(5)/ContentScroll(6). -->
            <FlowDocumentScrollViewer x:Name="ContentScroll"
                                      Focusable="True"
                                      TabIndex="6"
                                      IsToolBarVisible="False"
                                      VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto" />
        </Border>
    </DockPanel>
</Window>
